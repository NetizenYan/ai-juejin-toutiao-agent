# Copy to .env for local development. Never commit real secrets.

APP_ENV=development
APP_DEBUG_ERRORS=false

# CORS: keep explicit origins when credentials are enabled.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
CORS_ALLOW_CREDENTIALS=true

# MySQL. Prefer ASYNC_DATABASE_URL from a secret manager in deployed environments.
ASYNC_DATABASE_URL=
MYSQL_DRIVER=mysql+aiomysql
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=news_app
MYSQL_PASSWORD=
MYSQL_DATABASE=news_app
MYSQL_CHARSET=utf8mb4

# Redis. Leave REDIS_PASSWORD empty only for a local instance without auth.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=gpt-oss:20b
LLM_REASONING_EFFORT=
LLM_THINKING_ENABLED=false
LLM_TIMEOUT_SECONDS=90

# DeepSeek example:
# LLM_BASE_URL=https://api.deepseek.com
# DEEPSEEK_API_KEY=<set in local .env or secret manager>
# LLM_MODEL=deepseek-v4-pro
# LLM_REASONING_EFFORT=high
# LLM_THINKING_ENABLED=true
OLLAMA_NATIVE_BASE_URL=http://localhost:11434

EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=qwen3-embedding:4b
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_PROVIDER=
RERANKER_API_BASE_URL=
RERANKER_API_KEY=
RERANKER_API_MODEL=Pro/BAAI/bge-reranker-v2-m3

RAG_QUERY_ROUTER_ENABLED=true
RAG_RANKING=hybrid
RAG_COLLECTION_NAME=toutiao_news_claude
RAG_CHUNK_COLLECTION_NAME=toutiao_chunks_claude
RAG_RECALL_LIMIT=50
RAG_CHUNK_TYPE_FILTER=summary
RAG_EXPAND_BODY_EVIDENCE=true
RAG_BODY_CHUNKS_PER_PARENT=1
RAG_BODY_FALLBACK_SLOTS=0
RAG_ECON_COLLECTION_ENABLED=false
RAG_ECON_COLLECTION_NAME=toutiao_econ_chunks_candidate_20260621

ANSWER_CONTRACT_ENABLED=true
ANSWER_CONTRACT_DEFAULT_STYLE=plain_language
ANSWER_CONTRACT_DEFAULT_DETAIL=brief
ANSWER_CONTRACT_DEFAULT_MAX_POINTS=3
ANSWER_CONTRACT_REQUIRE_CITATIONS_FOR_NEWS=true
ANSWER_CONTRACT_REQUIRE_EVIDENCE_FOR_NEWS=true
ANSWER_CONTRACT_ALLOW_BACKGROUND=true
ANSWER_CONTRACT_BACKGROUND_POLICY=one_sentence_plain_explanation

ANSWER_VALIDATION_ENABLED=true
ANSWER_VALIDATION_MODE=shadow
ANSWER_VALIDATION_ENFORCE_ROUTES=econ_finance_query
ANSWER_VALIDATION_HALLUCINATION_LABEL=hallucination_risk
ANSWER_REWRITE_ON_FAIL=true
ANSWER_MAX_REWRITE_ATTEMPTS=1
ANSWER_THINKING_EVENT_ENABLED=false
ANSWER_VALIDATION_DONE_FIELD_ENABLED=true
ANSWER_VALIDATION_DONE_DETAIL_LEVEL=summary
ANSWER_VALIDATION_LOG_DIAGNOSTICS=true
ANSWER_VALIDATION_STORE_METADATA=true
ANSWER_VALIDATION_EXPOSE_INTERNAL_DETAILS=false
ANSWER_NO_EVIDENCE_POLICY=refuse_with_suggestion
ANSWER_LOW_CONFIDENCE_EVIDENCE_POLICY=refuse_if_not_supported

CONTEXT_MANAGER_ENABLED=true
SESSION_SUMMARY_ENABLED=true
LONG_TERM_MEMORY_ENABLED=false
CONTEXT_RECENT_TURNS=6
CONTEXT_SUMMARY_MESSAGE_THRESHOLD=12
CONTEXT_SUMMARY_CHAR_THRESHOLD=6000
CONTEXT_MAX_RECENT_EVIDENCE_IDS=8

MAX_TOOL_CALLS_PER_TURN=5
MAX_WEB_CALLS_PER_SESSION=3
MAX_FETCH_BYTES=1048576
TOOL_TIMEOUT_SECONDS=30
MAX_REDIRECTS=3
MAX_CHUNKS_PER_ANSWER=8

WEB_SEARCH_API_KEY=
WEB_ALLOWED_DOMAINS=
WEB_BLOCKED_DOMAINS=
WEB_CAPTURE_OUTPUT_DIR=work/web_captures
WEB_CAPTURE_VIEWPORT_WIDTH=1280
WEB_CAPTURE_VIEWPORT_HEIGHT=1600
WEB_CAPTURE_RENDER_MAX_CHARS=50000
OCR_PROVIDER=paddleocr
OCR_MIN_CONFIDENCE=0.35
OCR_CLEAN_MAX_CHARS=20000
OCR_MIN_CLEAN_CHARS=8

PG_HOST=127.0.0.1
PG_PORT=5433
PG_USER=postgres
PG_PASSWORD=
PG_DATABASE=toutiao_agent

QDRANT_UNIFIED_COLLECTION=news_chunks_v2
RAG_SEARCH_VERSION=v1
EMBEDDING_V2_MODEL=bge-m3
EMBEDDING_V2_DIM=1024
